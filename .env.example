# KRX Data Marketplace OPEN API.
# The normal pipeline does not require KRX; keep this for diagnostics only.
KRX_OPENAPI_KEY=
KRX_BASE_URL=https://data-dbg.krx.co.kr
KRX_STOCK_DAILY_PATH=/svc/apis/sto/stk_bydd_trd
KRX_KOSPI_DAILY_PATH=/svc/apis/sto/stk_bydd_trd
KRX_KOSDAQ_DAILY_PATH=/svc/apis/sto/ksq_bydd_trd
KRX_MARKETS=KOSPI,KOSDAQ

# OpenDART API. The OpenDART parameter name is crtfc_key.
OPENDART_API_KEY=
OPENDART_BASE_URL=https://opendart.fss.or.kr

# Korea Investment & Securities Open API.
# Keep AppKey/AppSecret as exact single-line values. Do not wrap long secrets.
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_DAILY_SLEEP_SECONDS=0.25
KIS_DAILY_TICKER_BATCH_SIZE=25
# Retry knobs for KIS rate-limit (EGW00201) replies: total tries, initial sleep, sleep multiplier.
KIS_DAILY_RETRY_ATTEMPTS=3
KIS_DAILY_RETRY_SLEEP_SECONDS=1.0
KIS_DAILY_RETRY_BACKOFF_MULTIPLIER=2.0

# Optional: leave empty unless you intentionally manage token refresh yourself.
KIS_ACCESS_TOKEN=

# Optional account-scoped KIS APIs. Not needed for the current price ingest scope.
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# Optional Naver Finance page source used to enrich KIS prices.
NAVER_FINANCE_BASE_URL=https://finance.naver.com
NAVER_FINANCE_API_BASE_URL=https://api.finance.naver.com
NAVER_FINANCE_USER_AGENT=Mozilla/5.0 finance-pi/0.1

# FRED API for CPI and official US rate series.
FRED_API_KEY=

# Bank of Korea ECOS API for Korean macroeconomic time series.
ECOS_API_KEY=

# Optional NPS holdings source overrides. Leave empty for the default
# data.go.kr discovery flow; set CSV URL + source date to pin a snapshot.
NPS_PUBLIC_DATA_CSV_URL=
NPS_PUBLIC_DATA_SOURCE_DATE=
NPS_PUBLIC_DATA_DISCOVER=

# Optional fixed token for the web admin. If empty, admin generates a one-run token.
FINANCE_PI_ADMIN_TOKEN=

# Optional admin tuning. Defaults are sized for a Raspberry Pi; raise with care.
# FINANCE_PI_ADMIN_MAX_THREADS=16
# FINANCE_PI_ADMIN_MAX_JOBS=1
# FINANCE_PI_ADMIN_MAX_PRICE_QUERIES=4
# FINANCE_PI_ADMIN_MAX_PRICE_TICKERS=500
# FINANCE_PI_ADMIN_MAX_PRICE_DAYS=3700
# FINANCE_PI_ADMIN_SCAN_PARQUET=   # set 1 only for short diagnostics (live row counts)

# Optional webhook (Slack/Discord-compatible) for daily/catchup failure notifications.
# Empty disables. Set FINANCE_PI_WEBHOOK_ALWAYS=1 to notify even on fully healthy runs.
FINANCE_PI_WEBHOOK_URL=
FINANCE_PI_WEBHOOK_ALWAYS=
