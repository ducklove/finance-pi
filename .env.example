# KRX Data Marketplace OPEN API
KRX_OPENAPI_KEY=
KRX_BASE_URL=https://data-dbg.krx.co.kr
KRX_STOCK_DAILY_PATH=/svc/apis/sto/stk_bydd_trd
KRX_KOSPI_DAILY_PATH=/svc/apis/sto/stk_bydd_trd
KRX_KOSDAQ_DAILY_PATH=/svc/apis/sto/ksq_bydd_trd
KRX_MARKETS=KOSPI,KOSDAQ

# OpenDART API. The OpenDART parameter name is crtfc_key.
OPENDART_API_KEY=
OPENDART_BASE_URL=https://opendart.fss.or.kr

# Korea Investment & Securities Open API, used for auxiliary cross-checks.
KIS_BASE_URL=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCESS_TOKEN=

# Optional account-scoped KIS APIs. Not needed for the current price cross-check scope.
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=
