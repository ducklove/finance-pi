# KRX Data Marketplace OPEN API.
# The normal pipeline does not require KRX; keep this for diagnostics only.
KRX_OPENAPI_KEY=
KRX_BASE_URL=https://data-dbg.krx.co.kr
KRX_STOCK_DAILY_PATH=/svc/apis/sto/stk_bydd_trd
KRX_KOSPI_DAILY_PATH=/svc/apis/sto/stk_bydd_trd
KRX_KOSDAQ_DAILY_PATH=/svc/apis/sto/ksq_bydd_trd
KRX_MARKETS=KOSPI,KOSDAQ

# OpenDART API. The OpenDART parameter name is crtfc_key.
OPENDART_API_KEY=
OPENDART_BASE_URL=https://opendart.fss.or.kr

# Korea Investment & Securities Open API.
# Keep AppKey/AppSecret as exact single-line values. Do not wrap long secrets.
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=

# Optional: leave empty unless you intentionally manage token refresh yourself.
KIS_ACCESS_TOKEN=

# Optional account-scoped KIS APIs. Not needed for the current price ingest scope.
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# Optional Naver Finance page source used to enrich KIS prices.
NAVER_FINANCE_BASE_URL=https://finance.naver.com
NAVER_FINANCE_API_BASE_URL=https://api.finance.naver.com
NAVER_FINANCE_USER_AGENT=Mozilla/5.0 finance-pi/0.1

# FRED API for CPI and official US rate series.
FRED_API_KEY=

# Optional fixed token for the web admin. If empty, admin generates a one-run token.
FINANCE_PI_ADMIN_TOKEN=
